<UserControl x:Class="MathTestSystem.StudentApp.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F4F6F8">
        <Border MaxWidth="360" MaxHeight="340"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="White" CornerRadius="6"
                BorderBrush="#D5D8DC" BorderThickness="1"
                Padding="36,32">
            <StackPanel>

                <TextBlock Text="Student Portal" FontSize="20" FontWeight="SemiBold"
                           Foreground="#1A5276" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Username" FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="8,6" Margin="0,0,0,14"
                         BorderBrush="#BDC3C7" BorderThickness="1"/>

                <TextBlock Text="Password" FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             FontSize="14" Padding="8,6" Margin="0,0,0,20"
                             BorderBrush="#BDC3C7" BorderThickness="1"/>

                <Button Content="Log In"
                        Command="{Binding LoginCommand}"
                        FontSize="14" Padding="0,8"
                        Background="#1A5276" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#C0392B" FontSize="12"
                           TextWrapping="Wrap" HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}"/>

                <TextBlock Text="Logging in…" FontSize="12" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0,8,0,0"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
