<UserControl x:Class="MathTestSystem.StudentApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MathTestSystem.StudentApp.ViewModels">

    <DockPanel Background="#F4F6F8">

        <!-- Overall score banner -->
        <Border DockPanel.Dock="Top" Background="#1A5276" Padding="20,14"
                Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Overall Score: " Foreground="#AED6F1" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OverallScore, StringFormat={}{0:F1}%}"
                           Foreground="White" FontSize="28" FontWeight="Bold" Margin="6,0,24,0"/>
                <TextBlock Text="{Binding OverallCorrect, StringFormat={}({0} correct /}"
                           Foreground="#AED6F1" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OverallTotal, StringFormat={}{0} total)}"
                           Foreground="#AED6F1" FontSize="14" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status / error -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding StatusMessage}"
                   Foreground="#C0392B" FontSize="13"
                   HorizontalAlignment="Center" Margin="0,16,0,0"
                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}"/>

        <!-- Loading indicator -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Loading your results…"
                   Foreground="#888" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <!-- Tree: Teachers → Exams → Tasks -->
        <TreeView ItemsSource="{Binding Teachers}"
                  Background="Transparent" BorderThickness="0"
                  Margin="16"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
            <TreeView.Resources>

                <!-- Teacher level -->
                <HierarchicalDataTemplate DataType="{x:Type vm:TeacherEntryViewModel}"
                                          ItemsSource="{Binding Exams}">
                    <Border Padding="6,4" Background="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👨‍🏫" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#1A5276"
                                       VerticalAlignment="Center">
                                <Run Text="Teacher "/>
                                <Run Text="{Binding TeacherId}"/>
                            </TextBlock>
                            <Border Background="#D6EAF8" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                                <TextBlock Text="{Binding ScoreSummary}" FontSize="12" Foreground="#1A5276"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </HierarchicalDataTemplate>

                <!-- Exam level -->
                <HierarchicalDataTemplate DataType="{x:Type vm:ExamEntryViewModel}"
                                          ItemsSource="{Binding Tasks}">
                    <Border Padding="4,3" Background="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock FontSize="13" Foreground="#2C3E50" VerticalAlignment="Center">
                                <Run Text="Exam "/>
                                <Run Text="{Binding ExamId}"/>
                                <Run Text=" — " Foreground="#888"/>
                                <Run Text="{Binding SubmittedAt, StringFormat={}{0:dd MMM yyyy}}" Foreground="#888"/>
                            </TextBlock>
                            <Border CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#D5F5E3"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Score}" Value="0">
                                                <Setter Property="Background" Value="#FADBD8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ScoreSummary}" FontSize="12" Foreground="#2C3E50"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </HierarchicalDataTemplate>

                <!-- Task level (leaf) -->
                <DataTemplate DataType="{x:Type vm:TaskEntry}">
                    <Border Padding="4,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12" Foreground="#555" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Run Text="{Binding Expression}"/>
                                <Run Text=" = "/>
                                <Run Text="{Binding StudentAnswer}"/>
                            </TextBlock>
                            <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✓ Correct"/>
                                        <Setter Property="Foreground" Value="#1E8449"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                <Setter Property="Foreground" Value="#C0392B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                <Setter Property="Text" Value="✗ Wrong"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                                <Setter Property="Text" Value="⚠ Error"/>
                                                <Setter Property="Foreground" Value="#D4AC0D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding CorrectAnswer, StringFormat={}  (correct: {0})}"
                                       FontSize="11" Foreground="#888" VerticalAlignment="Center"
                                       Visibility="{Binding IsCorrect, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>

            </TreeView.Resources>
        </TreeView>

    </DockPanel>
</UserControl>
