<Window x:Class="MathTestSystem.TeacherApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MathTestSystem.TeacherApp.ViewModels"
        xmlns:views="clr-namespace:MathTestSystem.TeacherApp.Views"
        Title="Math Test System – Teacher Portal"
        Height="700" Width="950" MinHeight="500" MinWidth="700">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="← Back"
                        Command="{Binding GoHomeCommand}"
                        Visibility="{Binding ShowBackButton, Converter={StaticResource BoolToVis}}"
                        Background="Transparent" Foreground="White"
                        BorderBrush="#5D6D7E"
                        Padding="10,4" Margin="0,0,16,0"/>

                <TextBlock Grid.Column="1"
                           Text="Math Test System – Teacher Portal"
                           Foreground="White" FontSize="17" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content area — swaps between views based on CurrentView type -->
        <ContentControl Content="{Binding CurrentView}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:LoginViewModel}">
                    <views:LoginView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                    <views:HomeView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:GradeViewModel}">
                    <views:GradeView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:StudentRecordsViewModel}">
                    <views:StudentRecordsView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

    </DockPanel>
</Window>
